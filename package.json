{
  "name": "musicapp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "set NODE_OPTIONS=--openssl-legacy-provider && react-native run-android",
    "ios": "set NODE_OPTIONS=--openssl-legacy-provider && react-native run-ios",
    "start": "set NODE_OPTIONS=--openssl-legacy-provider && react-native start",
    "postinstall": "patch-package",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
    "@react-native-community/cli": "^4.10.0",
    "@react-native-community/cli-platform-android": "^4.10.0",
    "react": "^17.0.1",
    "react-native": "^0.63.4",
    "react-native-fast-image": "^8.3.4",
    "react-native-gesture-handler": "^1.10.2",
    "react-native-reanimated": "^2.0.0",
    "react-native-safe-area-context": "^3.1.9",
    "react-native-svg": "^12.1.0",
    "react-native-swift": "^1.2.3",
    "react-native-track-player": "1.2.3"
  },
  "devDependencies": {
    "@babel/core": "^7.8.4",
    "@babel/runtime": "^7.8.4",
    "@react-native-community/eslint-config": "^1.1.0",
    "@types/jest": "^25.2.3",
    "@types/react-native": "^0.63.2",
    "@types/react-test-renderer": "^16.9.2",
    "@typescript-eslint/eslint-plugin": "^2.27.0",
    "@typescript-eslint/parser": "^2.27.0",
    "babel-jest": "^25.1.0",
    "babel-plugin-module-resolver": "^4.0.0",
    "eslint": "^6.5.1",
    "jest": "^25.1.0",
    "metro-react-native-babel-preset": "^0.59.0",
    "patch-package": "^6.5.1",
    "react-test-renderer": "16.13.1",
    "typescript": "^3.8.3"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  }
}
